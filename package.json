{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build && find public/build/assets -name '*.css' -o -name '*.js' | xargs -I{} sh -c 'brotli -q 11 -k -f \"$1\" -o \"${1}.br\" && gzip -9 -k -f \"$1\"' _ {}",
        "dev": "vite"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.2.2",
        "autoprefixer": "^10.4.27",
        "axios": "^1.15.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^3.0.0",
        "tailwindcss": "^4.2.2",
        "vite": "^8.0.0"
    },
    "dependencies": {
        "alpinejs": "^3.15.11"
    }
}
